---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

// Placeholder content for now
const title = "Kodingus - Full-Stack Creative Developer";
const description =
  "Full-Stack Creative Developer. Design, build, and deploy — all in one.";

const projects = (await getCollection("portfolio"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <section class="hero">
      <h1 class="hero-title">
        <span class="lang-en"
          >YOUR <span class="word-cycler" aria-label="ADAPTIVE"
            ><span class="word active">ADAPTIVE</span><span class="word"
              >DEDICATED</span
            ></span
          ><br />DIGITAL PARTNER</span
        >
        <span class="lang-id">PARTNER DIGITAL<br />ADAPTIF ANDA</span>
      </h1>
      <p class="hero-subtitle">
        <span class="lang-en">
          Full-stack developer handling design, development, and deployment —
          all in one.
        </span>
        <span class="lang-id">
          Full-stack developer yang menangani desain, development, dan
          deployment — semuanya dalam satu.
        </span>
      </p>
      <div class="cta-group">
        <a href="/portfolio" class="btn btn-primary">
          <span class="lang-en">View Work</span>
          <span class="lang-id">Lihat Karya</span>
        </a>
        <a href="/about" class="btn btn-secondary">
          <span class="lang-en">About Me</span>
          <span class="lang-id">Tentang Saya</span>
        </a>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>
          <span class="lang-en">SELECTED WORK</span>
          <span class="lang-id">KARYA PILIHAN</span>
        </h2>
        <a href="/portfolio" class="more-link">
          <span class="lang-en">See All &rarr;</span>
          <span class="lang-id">Lihat Semua &rarr;</span>
        </a>
      </div>

      <div class="project-grid">
        {
          projects.length > 0 ? (
            projects.map((project) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tags={project.data.tags}
                href={`/portfolio/${project.slug}`}
              />
            ))
          ) : (
            <p class="empty-state">
              <span class="lang-en">Projects coming soon...</span>
              <span class="lang-id">Proyek akan segera hadir...</span>
            </p>
          )
        }
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .hero {
    padding: clamp(3rem, 8vw, 8rem) 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 4rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5.5vw, 6rem);
    line-height: 1.05;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .word-cycler {
    display: inline-grid;
    justify-items: center;
    position: relative;
    vertical-align: baseline;
    line-height: 1;
    background: var(--color-text);
    color: var(--color-bg);
    padding: 0.18em 0.45em 0.22em;
    margin: 0 0.06em;
    letter-spacing: 0.01em;
    overflow: hidden;
    /* ensure grid auto-sizes to widest word */
    white-space: nowrap;
  }

  /* scanner sweep pseudo-element */
  .word-cycler::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-bg);
    transform: translateX(-101%);
    z-index: 1;
  }

  .word-cycler.scanning::after {
    animation: sweep 0.5s cubic-bezier(0.76, 0, 0.24, 1) forwards;
  }

  @keyframes sweep {
    0% {
      transform: translateX(-101%);
    }
    45% {
      transform: translateX(0%);
    }
    55% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(101%);
    }
  }

  .word-cycler .word {
    grid-area: 1 / 1;
    opacity: 0;
    clip-path: inset(0 100% 0 0);
    transition:
      opacity 0.35s ease,
      clip-path 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    white-space: nowrap;
    pointer-events: none;
    z-index: 2;
  }

  .word-cycler .word.active {
    opacity: 1;
    clip-path: inset(0 0% 0 0);
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    /* bypass clip-path entirely — use opacity only */
    .word-cycler .word {
      clip-path: none !important;
      transition: opacity 0.2s ease;
    }
    .word-cycler.scanning::after {
      animation: none;
    }
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.3rem);
    max-width: 560px;
    margin-bottom: 2.5rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
  }

  .btn {
    display: inline-block;
    padding: 0.8rem 1.6rem;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    border: 2px solid var(--color-text);
  }

  .btn-primary {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--color-text);
    opacity: 1;
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
  }

  .btn-secondary:hover {
    background: var(--color-text);
    color: var(--color-bg);
    opacity: 1;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--color-text);
    padding-bottom: 1rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: 2rem;
  }

  .more-link {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .placeholder-text {
    font-style: italic;
    color: var(--color-text-muted);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    padding: 2rem;
    background: var(--color-bg-alt);
    border-radius: 4px;
  }
</style>

<script>
  const cycler = document.querySelector(".word-cycler");
  if (cycler) {
    const words = cycler.querySelectorAll<HTMLElement>(".word");
    let current = 0;

    setInterval(() => {
      // trigger the sweep animation
      cycler.classList.remove("scanning");
      void (cycler as HTMLElement).offsetWidth; // force reflow
      cycler.classList.add("scanning");

      // swap active word halfway through the sweep
      setTimeout(() => {
        words[current].classList.remove("active");
        current = (current + 1) % words.length;
        words[current].classList.add("active");
      }, 225);
    }, 2800);
  }
</script>
