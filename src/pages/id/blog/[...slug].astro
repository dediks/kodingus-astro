---
import { getCollection } from 'astro:content';
import BlogPostTemplate from "../../../components/templates/blog/BlogPostTemplate.astro";

export async function getStaticPaths() {
	const posts = await getCollection('blog');
  const idPosts = posts.filter(post => post.slug.startsWith('id/'));
	return idPosts.map((post) => ({
		params: { slug: post.slug.replace('id/', '') },
		props: post,
	}));
}

const post = Astro.props;
---

<BlogPostTemplate post={post} lang="id" />
