---
import { getCollection } from 'astro:content';
import BlogPostTemplate from "../../components/templates/blog/BlogPostTemplate.astro";

export async function getStaticPaths() {
	const posts = await getCollection('blog');
  const enPosts = posts.filter(post => post.slug.startsWith('en/'));
	return enPosts.map((post) => ({
		params: { slug: post.slug.replace('en/', '') },
		props: post,
	}));
}

const post = Astro.props;
---

<BlogPostTemplate post={post} lang="en" />
