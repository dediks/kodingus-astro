---
import { getCollection } from 'astro:content';
import PortfolioPostTemplate from "../../components/templates/portfolio/PortfolioPostTemplate.astro";

export async function getStaticPaths() {
	const posts = await getCollection('portfolio');
  const enPosts = posts.filter(post => post.id.startsWith('en/'));
	return enPosts.map((post) => ({
		params: { slug: post.id.replace('en/', '') },
		props: post,
	}));
}

const post = Astro.props;
---

<PortfolioPostTemplate post={post} lang="en" />
