---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "../../i18n/utils";

interface Props {
  lang: 'en' | 'id';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const title = "Kodingus | Full-Stack Creative Developer";
const description = "Full-Stack Creative Developer. Design, build, and deploy — all in one.";

const projects = (await getCollection("portfolio"))
  .filter((project) => project.id.startsWith(`${lang}/`))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const latestPosts = (await getCollection("blog"))
  .filter((post) => post.id.startsWith(`${lang}/`))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "@id": "https://kodingus.com/#person",
          "name": "Dedik",
          "url": "https://kodingus.com",
          "jobTitle": "Full-Stack Creative Developer",
          "description": "Full-stack developer handling design, development, and deployment — all in one."
        },
        {
          "@type": "WebSite",
          "@id": "https://kodingus.com/#website",
          "url": "https://kodingus.com",
          "name": "Kodingus",
          "description": "Full-Stack Creative Developer. Design, build, and deploy — all in one.",
          "author": { "@id": "https://kodingus.com/#person" }
        }
      ]
    })} />
  </Fragment>

  <Header />

  <main>
    <section class="hero">
      <h1 class="hero-title">
        {t('home.hero.title_part1')} <span class="word-cycler" aria-label={t('home.hero.adaptive')}
          ><span class="word active">{t('home.hero.adaptive')}</span><span class="word"
            >{t('home.hero.dedicated')}</span
          ></span
        ><br />{t('home.hero.title_part2')}
      </h1>
      <p class="hero-subtitle">
        {t('home.hero.subtitle')}
      </p>
      <div class="cta-group">
        <a href={lang === 'en' ? "/portfolio" : `/${lang}/portfolio`} class="btn btn-primary">
          {t('home.cta.view_work')}
        </a>
        <a href={lang === 'en' ? "/about" : `/${lang}/about`} class="btn btn-secondary">
          {t('home.cta.about_me')}
        </a>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>
          {t('home.selected_work')}
        </h2>
        <a href={lang === 'en' ? "/portfolio" : `/${lang}/portfolio`} class="more-link">
          {t('home.see_all')}
        </a>
      </div>

      <div class="project-grid">
        {
          projects.length > 0 ? (
            projects.map((project) => {
              // Strip the lang prefix from slug for the link
              const [, ...slugParts] = project.id.split('/');
              const slug = slugParts.join('/');
              return (
                <div class="project-card-wrapper">
                  <ProjectCard
                    title={project.data.title}
                    description={project.data.description}
                    tags={project.data.tags}
                    href={lang === 'en' ? `/portfolio/${slug}` : `/${lang}/portfolio/${slug}`}
                  />
                </div>
              )
            })
          ) : (
            <p class="empty-state">
              {t('home.no_projects')}
            </p>
          )
        }
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>
          {t('home.latest_writings')}
        </h2>
        <a href={lang === 'en' ? "/blog" : `/${lang}/blog`} class="more-link">
          {t('home.see_all')}
        </a>
      </div>

      <ul class="post-list">
        {
          latestPosts.length > 0 ? (
            latestPosts.map((post) => {
              const [, ...slugParts] = post.id.split('/');
              const slug = slugParts.join('/');
              return (
                <li>
                  <a href={lang === 'en' ? `/blog/${slug}` : `/${lang}/blog/${slug}`}>
                    <span class="post-date">
                      {post.data.pubDate.toLocaleDateString(lang === 'en' ? 'en-us' : 'id-ID', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric',
                      })}
                    </span>
                    <span class="post-title">
                      {post.data.title}
                    </span>
                  </a>
                </li>
              )
            })
          ) : (
            <li class="empty-state">
              {t('home.no_articles')}
            </li>
          )
        }
      </ul>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .hero {
    padding: clamp(3rem, 8vw, 8rem) 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 4rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5.5vw, 6rem);
    line-height: 1.05;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .word-cycler {
    display: inline-grid;
    justify-items: center;
    position: relative;
    vertical-align: baseline;
    line-height: 1;
    background: var(--color-text);
    color: var(--color-bg);
    padding: 0.18em 0.45em 0.22em;
    margin: 0 0.06em;
    letter-spacing: 0.01em;
    overflow: hidden;
    /* ensure grid auto-sizes to widest word */
    white-space: nowrap;
  }

  /* scanner sweep pseudo-element */
  .word-cycler::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-bg);
    transform: translateX(-101%);
    z-index: 1;
  }

  .word-cycler.scanning::after {
    animation: sweep 0.5s cubic-bezier(0.76, 0, 0.24, 1) forwards;
  }

  @keyframes sweep {
    0% {
      transform: translateX(-101%);
    }
    45% {
      transform: translateX(0%);
    }
    55% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(101%);
    }
  }

  .word-cycler .word {
    grid-area: 1 / 1;
    opacity: 0;
    clip-path: inset(0 100% 0 0);
    transition:
      opacity 0.35s ease,
      clip-path 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    white-space: nowrap;
    pointer-events: none;
    z-index: 2;
  }

  .word-cycler .word.active {
    opacity: 1;
    clip-path: inset(0 0% 0 0);
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    /* bypass clip-path entirely — use opacity only */
    .word-cycler .word {
      clip-path: none !important;
      transition: opacity 0.2s ease;
    }
    .word-cycler.scanning::after {
      animation: none;
    }
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.3rem);
    max-width: 560px;
    margin-bottom: 2.5rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
  }

  .btn {
    display: inline-block;
    padding: 0.8rem 1.6rem;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    border: 2px solid var(--color-text);
  }

  .btn-primary {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--color-text);
    opacity: 1;
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
  }

  .btn-secondary:hover {
    background: var(--color-text);
    color: var(--color-bg);
    opacity: 1;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--color-text);
    padding-bottom: 1rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: 2rem;
  }

  .more-link {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .placeholder-text {
    font-style: italic;
    color: var(--color-text-muted);
  }

  .project-grid {
    display: flex;
    overflow-x: auto;
    gap: 2rem;
    padding-bottom: 1.5rem; /* extra padding for scrollbar */
    scroll-snap-type: x mandatory;
  }

  /* Style the scrollbar to look sleek */
  .project-grid::-webkit-scrollbar {
    height: 8px;
  }
  .project-grid::-webkit-scrollbar-track {
    background: var(--color-bg-alt);
    border-radius: 4px;
  }
  .project-grid::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 4px;
  }
  .project-grid::-webkit-scrollbar-thumb:hover {
    background: var(--color-text-muted);
  }

  .project-card-wrapper {
    flex: 0 0 min(85vw, 350px);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
  }
  
  /* Ensure the inner project-card grows to fill the wrapper height if they differ */
  .project-card-wrapper > :global(.project-card) {
    flex: 1;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    padding: 2rem;
    background: var(--color-bg-alt);
    border-radius: 4px;
  }

  .section {
    margin-bottom: 6rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-list li {
    border-bottom: 1px solid var(--color-border);
    padding: 0 1rem;
    margin: 0 -1rem;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  .post-list li:hover {
    transform: translateY(-3px);
    border-color: var(--color-text);
    box-shadow: 4px 4px 0px var(--color-text);
  }

  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1.5rem 0;
    transition: opacity 0.3s ease;
  }

  .post-list a:hover {
    text-decoration: none;
    opacity: 1;
  }

  .post-date {
    font-family: monospace;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-right: 2rem;
    min-width: 120px;
    flex-shrink: 0;
  }

  .post-title {
    font-size: 1.1rem;
    font-weight: 700;
  }

  @media (max-width: 600px) {
    .post-list a {
      flex-direction: column;
      gap: 0.35rem;
    }

    .post-date {
      margin-right: 0;
    }
  }
</style>

<script>
  const cycler = document.querySelector(".word-cycler");
  if (cycler) {
    const words = cycler.querySelectorAll<HTMLElement>(".word");
    let current = 0;

    setInterval(() => {
      // trigger the sweep animation
      cycler.classList.remove("scanning");
      void (cycler as HTMLElement).offsetWidth; // force reflow
      cycler.classList.add("scanning");

      // swap active word halfway through the sweep
      setTimeout(() => {
        words[current].classList.remove("active");
        current = (current + 1) % words.length;
        words[current].classList.add("active");
      }, 225);
    }, 2800);
  }
</script>
