---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from "../../../i18n/utils";

interface Props {
  lang: 'en' | 'id';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const title = "Portfolio | Kodingus";
const description = "Selected work showcasing engineering, design, and creativity.";

const projects = (await getCollection('portfolio'))
  .filter((project) => project.id.startsWith(`${lang}/`))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const portfolioSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": Astro.url.href,
  "author": {
    "@type": "Person",
    "@id": "https://kodingus.com/#person",
    "name": "Dedik",
    "url": "https://kodingus.com"
  },
  "hasPart": projects.map((project) => {
    const [, ...slugParts] = project.id.split('/');
    const slug = slugParts.join('/');
    const projectUrl = new URL(
      lang === 'en' ? `/portfolio/${slug}` : `/${lang}/portfolio/${slug}`,
      Astro.site ?? Astro.url.origin
    ).href;
    return {
      "@type": "CreativeWork",
      "name": project.data.title,
      "description": project.data.description,
      "url": projectUrl,
      "author": { "@id": "https://kodingus.com/#person" }
    };
  })
});
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={portfolioSchema} />
  </Fragment>

  <Header />

  
  <main>
    <section>
      <h1>
        {t('portfolio.heading')}
      </h1>
      <div class="project-grid">
        {projects.length > 0 ? (
          projects.map((project) => {
            const [, ...slugParts] = project.id.split('/');
            const slug = slugParts.join('/');
            return (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tags={project.data.tags}
                href={lang === 'en' ? `/portfolio/${slug}` : `/${lang}/portfolio/${slug}`}
              />
            );
          })
        ) : (
          <p class="empty-state">
            {t('portfolio.no_projects')}
          </p>
        )}
      </div>

      <div class="more-divider">
        <div class="more-divider-rule"></div>
        <div class="more-divider-body">
          <span class="more-divider-label">{t('portfolio.more_label')}</span>
          <p class="more-divider-text">{t('portfolio.more_coming')}</p>
        </div>
        <div class="more-divider-count">
          <span class="count-number">{projects.length}</span>
          <span class="count-label">{t('portfolio.shown')}</span>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  h1 {
    font-size: 3rem;
    margin-bottom: 3rem;
    text-transform: uppercase;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 4.5rem 2.5rem; /* row-gap column-gap */
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    padding: 3rem;
    background: var(--color-bg-alt);
    border-radius: 4px;
  }

  .more-divider {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-border);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
  }

  .more-divider-rule {
    display: none; /* the border-top on parent is the rule */
  }

  .more-divider-body {
    flex: 1;
  }

  .more-divider-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .more-divider-text {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 42ch;
  }

  .more-divider-count {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
  }

  .count-number {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .count-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  @media (max-width: 600px) {
    .more-divider {
      flex-direction: column;
    }
    .more-divider-count {
      align-items: flex-start;
    }
  }
</style>
