---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from "../../../i18n/utils";

interface Props {
  lang: 'en' | 'id';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const title = "Portfolio | Kodingus";
const description = "Selected work showcasing engineering, design, and creativity.";

const projects = (await getCollection('portfolio'))
  .filter((project) => project.slug.startsWith(`${lang}/`))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const portfolioSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": Astro.url.href,
  "author": {
    "@type": "Person",
    "@id": "https://kodingus.com/#person",
    "name": "Dedik",
    "url": "https://kodingus.com"
  },
  "hasPart": projects.map((project) => {
    const [, ...slugParts] = project.slug.split('/');
    const slug = slugParts.join('/');
    const projectUrl = new URL(
      lang === 'en' ? `/portfolio/${slug}` : `/${lang}/portfolio/${slug}`,
      Astro.site ?? Astro.url.origin
    ).href;
    return {
      "@type": "CreativeWork",
      "name": project.data.title,
      "description": project.data.description,
      "url": projectUrl,
      "author": { "@id": "https://kodingus.com/#person" }
    };
  })
});
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={portfolioSchema} />
  </Fragment>

  <Header />

  
  <main>
    <section>
      <h1>
        {t('portfolio.heading')}
      </h1>
      <div class="project-grid">
        {projects.length > 0 ? (
          projects.map((project) => {
            const [, ...slugParts] = project.slug.split('/');
            const slug = slugParts.join('/');
            return (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tags={project.data.tags}
                href={lang === 'en' ? `/portfolio/${slug}` : `/${lang}/portfolio/${slug}`}
              />
            );
          })
        ) : (
          <p class="empty-state">
            {t('portfolio.no_projects')}
          </p>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  h1 {
    font-size: 3rem;
    margin-bottom: 3rem;
    text-transform: uppercase;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 4.5rem 2.5rem; /* row-gap column-gap */
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    padding: 3rem;
    background: var(--color-bg-alt);
    border-radius: 4px;
  }
</style>
